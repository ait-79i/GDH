<div class="wrap">
	<h1>Email Settings</h1>

	{% if show_saved_notice %}
		<div class="notice notice-success is-dismissible">
			<p>Paramètres e-mail enregistrés.</p>
		</div>
	{% endif %}

	{% if last_err %}
		<div class="notice notice-error is-dismissible">
			<p>
				<strong>Dernière erreur d'envoi :</strong>
				{{ last_err|e }}</p>
		</div>
	{% endif %}

	<h2>Éditer le template</h2>
	<form method="post" action="{{ admin_post_url }}">
		<input type="hidden" name="action" value="gdh_save_email_settings"/>
		{{ nonce_field|raw }}
		<table class="form-table" role="presentation">
			<tr>
				<th scope="row">
					<label for="gdh_subject">Sujet</label>
				</th>
				<td>
					<div style="margin-bottom:10px;">
						{% for var in subject_vars %}
							{% set placeholder = '{{' ~ var ~ '}}' %}
							<button type="button" class="button button-small copy-var" data-var="{{ placeholder }}" title="Cliquez pour copier" style="margin:2px;">{{ placeholder }}</button>
						{% endfor %}
					</div>
					<input type="text" id="gdh_subject" name="subject" class="regular-text" value="{{ subject_value|e }}" required/>
				</td>
			</tr>
			<tr>
				<th scope="row">
					<label for="gdh_body">Corps</label>
				</th>
				<td>
					<div style="margin-bottom:-20px;">
						{% for var in vars %}
							{% set placeholder = '{{' ~ var ~ '}}' %}
							<button type="button" class="button button-small copy-var" data-var="{{ placeholder }}" title="Cliquez pour copier" style="margin:2px;">{{ placeholder }}</button>
						{% endfor %}
					</div>
					{{ editor_html|raw }}
				</td>
			</tr>
		</table>
		<p class="submit">
			<button type="submit" class="button button-primary">Enregistrer le template</button>
		</p>
	</form>

	<script>
		document.addEventListener("click", function (e) {
if (e.target && e.target.classList.contains("copy-var")) {
e.preventDefault();
const varText = e.target.getAttribute("data-var");
if (navigator.clipboard && navigator.clipboard.writeText) {
navigator.clipboard.writeText(varText);
const orig = e.target.innerText;
e.target.innerText = "Copié!";
setTimeout(() => {
e.target.innerText = orig;
}, 1000);
}
}
});
	</script>
</div>
