<div class="gdh-rdv-step-content" data-step="3">
    <h3>Vos informations</h3>
    
    <div class="gdh-rdv-field-group">
        <div class="gdh-rdv-field">
            <label for="first_name">Prénom *</label>
            <input type="text" 
                   id="first_name" 
                   name="first_name" 
                   required>
        </div>
        <div class="gdh-rdv-field">
            <label for="last_name">Nom *</label>
            <input type="text" 
                   id="last_name" 
                   name="last_name" 
                   required>
        </div>
    </div>
    
    <div class="gdh-rdv-field-group">
        <div class="gdh-rdv-field">
            <label for="email">Email *</label>
            <input type="email" 
                   id="email" 
                   name="email" 
                   required>
        </div>
        <div class="gdh-rdv-field">
            <label for="phone">Téléphone *</label>
            <input type="tel" 
                   id="phone" 
                   name="phone" 
                   required>
        </div>
    </div>
    
    <div class="gdh-rdv-field">
        <label class="gdh-rdv-checkbox">
            <input type="checkbox" 
                   name="accept_terms" 
                   required>
            <span class="gdh-rdv-checkmark"></span>
            J'accepte les conditions générales de vente *
        </label>
    </div>
</div>